page {
  background: #f5f7fa;
  color: #1f2937;
  font-size: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.06);
  transition: transform 220ms ease, box-shadow 220ms ease, opacity 220ms ease;
  will-change: transform, opacity;
}

.primary-btn {
  background: #0057ff;
  color: #ffffff;
  border-radius: 999rpx;
}

.enter {
  opacity: 0;
  transform: translateY(18rpx) scale(0.99);
  animation: fade-slide-up 340ms cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
}

.delay-1 {
  animation-delay: 70ms;
}

.delay-2 {
  animation-delay: 130ms;
}

.delay-3 {
  animation-delay: 190ms;
}

.btn-press {
  transform: scale(0.98);
  opacity: 0.92;
}

@keyframes fade-slide-up {
  0% {
    opacity: 0;
    transform: translateY(18rpx) scale(0.99);
  }

  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes soft-pulse {
  0% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.03);
  }

  100% {
    transform: scale(1);
  }
}
